# La contraseña del registry vive en .kamal/secrets.local (gitignored),
# como `export KAMAL_REGISTRY_PASSWORD=...`. Kamal la lee solo: basta
# `kamal deploy`, sin source previo. Si no existe el archivo, cae al
# valor del entorno (vacío = el error "flag needs an argument: 'p'").
KAMAL_REGISTRY_PASSWORD=$(. .kamal/secrets.local 2>/dev/null; echo $KAMAL_REGISTRY_PASSWORD)
