# La clave del registry vive en .kamal/secrets.local (gitignored), en
# formato `export KAMAL_REGISTRY_PASSWORD=...`. Se extrae con sed para
# que Kamal no interpole la variable (vacía) antes de ejecutar el
# comando. Basta `kamal deploy`, sin source previo.
KAMAL_REGISTRY_PASSWORD=$(sed -n 's/^export KAMAL_REGISTRY_PASSWORD=//p' .kamal/secrets.local | tr -d '"')
