# La clave del registry vive en .kamal/secrets.local (gitignored), en
# formato `export KAMAL_REGISTRY_PASSWORD='...'`. Se extrae con sed y
# se quitan las comillas; no se nombra la variable dentro del comando
# porque Kamal la interpolaría (vacía) antes de ejecutarlo.
KAMAL_REGISTRY_PASSWORD=$(sed -n "s/^export KAMAL_REGISTRY_PASSWORD=//p" .kamal/secrets.local | tr -d "\"'")
